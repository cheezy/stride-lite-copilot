{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stride-lite-copilot-hook.sh pre",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stride-lite-copilot-hook.sh post",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Write|create",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stride-lite-copilot-hook.sh post",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
